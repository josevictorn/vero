// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  LAWYER
  ASSISTANT
  FINANCE
  CLIENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  lawyer Lawyer?

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  email     String
  cellphone String
  createdAt DateTime @default(now()) @map("created_at")

  lawyers Lawyer[]
  leads   Lead[]

  @@map("workspaces")
}

model Lawyer {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  workspaceId String   @map("workspace_id")
  cellphone   String
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@map("lawyers")
}

model Lead {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  lawyerId    String   @map("lawyer_id")
  name        String
  cellphone   String
  email       String
  createdAt   DateTime @default(now()) @map("created_at")

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lawyer       Lawyer         @relation(fields: [lawyerId], references: [id])
  caseAnalyses CaseAnalysis[]

  @@map("leads")
}

model ScreeningFlow {
  id        String   @id @default(uuid())
  caseType  String   @map("case_type")
  questions Json
  createdAt DateTime @default(now()) @map("created_at")

  aiSessions AiSession[]

  @@map("screening_flows")
}

model AiSession {
  id              String   @id @default(uuid())
  screeningFlowId String   @map("screening_flow_id")
  chatId          String   @map("chat_id")
  status          String
  chatState       Json     @map("chat_state")
  name            String
  cellphone       String
  isThirdParty    Boolean  @default(false) @map("is_third_party")
  createdAt       DateTime @default(now()) @map("created_at")

  screeningFlow ScreeningFlow  @relation(fields: [screeningFlowId], references: [id], onDelete: Cascade)
  caseAnalyses  CaseAnalysis[]

  @@map("ai_sessions")
}

model CaseAnalysis {
  id                  String   @id @default(uuid())
  aiSessionId         String   @map("ai_session_id")
  leadId              String   @map("lead_id")
  title               String
  viabilityLabel      String   @map("viability_label")
  analysisText        String   @map("analysis_text")
  estimatedComplexity String   @map("estimated_complexity")
  mainLegalBase       String   @map("main_legal_base")
  createdAt           DateTime @default(now()) @map("created_at")

  aiSession AiSession @relation(fields: [aiSessionId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("case_analyses")
}
